---
import Layout from "../../layouts/Layout.astro";
import Content from "../../components/Content.svelte";
import Title from "../../components/Title.svelte";
import Title3 from "../../components/Title3.svelte";
import TextBox from "../../components/TextBox.svelte";
---

<Layout title="Team Undefined - Our Robots">
    <Content column big>
        <Title3>
            <b style="color: rgb(81, 146, 89);">Our <span style="color: white;">Robots</span></b>
        </Title3>
        <TextBox>
            <p style="text-align: center; font-size: 1.2rem; line-height: 1.8; max-width: 800px; margin: 0 auto;">
                Each season brings a new challenge, and each challenge inspires a new robot. Explore our journey through innovation, engineering, and determination.
            </p>
        </TextBox>
    </Content>

    <br/><br/>

    <!-- 2025 Robot - BOTZILLA -->
    <Content column big>
        <div class="robot-section">
            <Title3>
                <b style="color: white;">Season 2025: <span style="color: rgb(81, 146, 89);">BOTZILLA</span></b>
            </Title3>
            <TextBox>
                <div class="robot-content">
                    <div class="robot-description">
                        <h4 class="robot-subtitle">DECODE</h4>
                        <p>Meet botzilla, our most massive robot, but one we are very proud of. 
                            All the effort has led to one of the most innovative robots of this season, 
                            characterized by precision, strength and a little bit of craftsmanship.</p>
                        <br/>
                        <p><b style="color: rgb(81, 146, 89);">Key Features:</b></p>
                        <ul class="features-list">
                            <li>Continuous tracking</li>
                            <li>Parallel execution</li>
                            <li>Four color sensor indexing</li>
                            <li>Compact drivetrain - 550RPM</li>
                            <li>Retry and fail gracefully</li>
                            <li>270 degree turret with continuous tracking</li>
                        </ul>
                    </div>

                    <div class="video-container">
                        <div class="video-wrapper">
                            <iframe
                                src="https://www.youtube.com/embed/PfpKA2cZg1A?si=lce8Pwc3IwSGoCwn"
                                title="Botzilla - Team Undefined Robot 2025"
                                frameborder="0"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                allowfullscreen
                            ></iframe>
                        </div>
                    </div>
                    <!-- CAD Gallery -->
                    <div class="gallery-grid">
                        <div class="gallery-item" onclick="openLightbox('/img/robots/botzilla/cad-main-render.png', 'CAD Main Render')">
