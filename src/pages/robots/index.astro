<!-- Lightbox Modal -->
<div id="lightbox" class="lightbox" onclick="closeLightbox()">
    <span class="lightbox-close">&times;</span>
    <div class="lightbox-content" onclick="event.stopPropagation()">
        <img id="lightbox-img" src="" alt="" />
        <div class="lightbox-caption" id="lightbox-caption"></div>
    </div>
    <button class="lightbox-nav lightbox-prev" onclick="event.stopPropagation(); navigateLightbox(-1)">&lsaquo;</button>
    <button class="lightbox-nav lightbox-next" onclick="event.stopPropagation(); navigateLightbox(1)">&rsaquo;</button>
</div>

<script>
    // Lightbox functionality
    let currentImageIndex = 0;
    const images = [
        { src: '/img/robots/botzilla/BOTZILLA THE KING.jpg', caption: 'BOTZILLA - Main Photo' },
        { src: '/img/robots/botzilla/cad-main-render.png', caption: 'BOTZILLA - CAD Main Render' },
        { src: '/img/robots/botzilla/cad-top-view.png', caption: 'BOTZILLA - CAD Top View' },
        { src: '/img/robots/botzilla/cad-screenshot-1.png', caption: 'BOTZILLA - CAD View 1' },
        { src: '/img/robots/botzilla/cad-screenshot-2.png', caption: 'BOTZILLA - CAD View 2' },
        { src: '/img/robots/botzilla/cad-screenshot-3.png', caption: 'BOTZILLA - CAD View 3' },
        { src: '/img/robots/vik/robot1.png', caption: 'VIK - CAD overview' },
        { src: '/img/robots/vik/robot2.png', caption: 'VIK - CAD rear view' },
        { src: '/img/robots/vik/robot3.png', caption: 'VIK - CAD drivetrain' },
        { src: '/img/robots/vik/robot4.png', caption: 'VIK - CAD top view' },
        { src: '/img/robots/frank/side robot look.jpeg', caption: 'FRANK - Side View' },
        { src: '/img/robots/frank/side robot look2.jpeg', caption: 'FRANK - Side View 2' },
        { src: '/img/robots/al abdulah 2/main.jpeg', caption: 'AL ABDULAH - Main Photo' },
        { src: '/img/robots/al abdulah 2/photo-1.jpeg', caption: 'AL ABDULAH - Photo' },
        { src: '/img/robots/Bobilda/photo-1.jpeg', caption: 'BOBILDA - Photo' }
    ];

    function openLightbox(imgSrc: string, caption: string) {
        const lightbox = document.getElementById('lightbox');
        const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
        const lightboxCaption = document.getElementById('lightbox-caption');

        if (lightbox && lightboxImg && lightboxCaption) {
            const matchedIndex = images.findIndex((img) => img.src === imgSrc);
            if (matchedIndex === -1) {
                images.push({ src: imgSrc, caption });
                currentImageIndex = images.length - 1;
            } else {
                currentImageIndex = matchedIndex;
            }

            lightboxImg.src = imgSrc;
            lightboxCaption.textContent = caption;
            lightbox.style.display = 'flex';
            document.body.style.overflow = 'hidden'; // Prevent background scrolling
        }
    }

    function closeLightbox() {
        const lightbox = document.getElementById('lightbox');
        if (lightbox) {
            lightbox.style.display = 'none';
            document.body.style.overflow = 'auto';
        }
    }

    function isLightboxOpen() {
        const lightbox = document.getElementById('lightbox');
        return lightbox?.style.display === 'flex';
    }

    function navigateLightbox(direction: number) {
        if (!isLightboxOpen() || images.length === 0) {
            return;
        }

        currentImageIndex += direction;

        // Wrap around
        if (currentImageIndex < 0) {
            currentImageIndex = images.length - 1;
        } else if (currentImageIndex >= images.length) {
            currentImageIndex = 0;
        }

        const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
        const lightboxCaption = document.getElementById('lightbox-caption');

        if (lightboxImg && lightboxCaption) {
            lightboxImg.src = images[currentImageIndex].src;
            lightboxCaption.textContent = images[currentImageIndex].caption;
        }
    }

    // Close lightbox with Escape key
    document.addEventListener('keydown', (e) => {
        if (!isLightboxOpen()) {
            return;
        }

        if (e.key === 'Escape') {
            closeLightbox();
        } else if (e.key === 'ArrowLeft') {
            navigateLightbox(-1);
        } else if (e.key === 'ArrowRight') {
            navigateLightbox(1);
        }
    });

    // Make functions globally available
    (window as any).openLightbox = openLightbox;
    (window as any).closeLightbox = closeLightbox;
    (window as any).navigateLightbox = navigateLightbox;

    // Keyboard support for clickable gallery tiles and close control
    document.querySelectorAll<HTMLElement>('.gallery-item').forEach((item) => {
        item.setAttribute('role', 'button');
        item.setAttribute('tabindex', '0');
        item.addEventListener('keydown', (event) => {
            if (event.key === 'Enter' || event.key === ' ') {
                event.preventDefault();
                item.click();
            }
        });
    });

    const lightboxClose = document.querySelector<HTMLElement>('.lightbox-close');
    if (lightboxClose) {
        lightboxClose.setAttribute('role', 'button');
        lightboxClose.setAttribute('tabindex', '0');
        lightboxClose.addEventListener('keydown', (event) => {
            if (event.key === 'Enter' || event.key === ' ') {
                event.preventDefault();
                closeLightbox();
            }
        });
    }
</script>



<style>
    .robot-section {
        margin: 40px 0;
    }

    .robot-content {
        display: flex;
        flex-direction: column;
        gap: 40px;
    }

    .robot-hero-image {
        width: 100%;
        max-width: 900px;
        margin: 0 auto;
        border: 2px solid rgba(81, 146, 89, 0.4);
        border-radius: 8px;
        overflow: hidden;
        background: rgba(0, 0, 0, 0.5);
    }

    .robot-hero-image img {
        width: 100%;
        height: auto;
        display: block;
        transition: transform 0.3s ease;
    }

    .robot-hero-image:hover img {
        transform: scale(1.02);
    }

    .robot-description {
        font-family: 'Rajdhani', sans-serif;
        font-size: 1.1rem;
        line-height: 1.8;
        color: rgba(255, 255, 255, 0.9);
    }

    .robot-subtitle {
        font-family: 'Orbitron', monospace;
        font-size: 1.3rem;
        font-weight: 700;
        color: rgb(81, 146, 89);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 15px;
    }

    .features-list {
        list-style: none;
        padding: 0;
        margin: 15px 0;
    }

    .features-list li {
        padding: 8px 0 8px 25px;
        position: relative;
    }

    .features-list li::before {
        content: '▸';
        position: absolute;
        left: 0;
        color: rgb(81, 146, 89);
        font-weight: bold;
    }

    /* Video Container */
    .video-container {
        width: 100%;
        max-width: 900px;
        margin: 0 auto;
    }

    .video-wrapper {
        position: relative;
        padding-bottom: 56.25%; /* 16:9 aspect ratio */
        height: 0;
        overflow: hidden;
        border: 2px solid rgba(81, 146, 89, 0.4);
        border-radius: 8px;
        background: rgba(0, 0, 0, 0.5);
    }

    .video-wrapper iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

    /* Gallery Grid */
    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-top: 30px;
    }

    .gallery-item {
        position: relative;
        aspect-ratio: 4/3;
        overflow: hidden;
        border: 2px solid rgba(81, 146, 89, 0.3);
        border-radius: 8px;
        background: rgba(0, 0, 0, 0.5);
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .gallery-item:hover {
        border-color: rgba(81, 146, 89, 0.7);
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(81, 146, 89, 0.3);
    }

    .gallery-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .gallery-item:hover img {
        transform: scale(1.1);
    }

    .gallery-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(to top, rgba(0, 0, 0, 0.9), transparent);
        padding: 20px 15px 15px;
        transform: translateY(100%);
        transition: transform 0.3s ease;
    }

    .gallery-item:hover .gallery-overlay {
        transform: translateY(0);
    }

    .gallery-overlay p {
        font-family: 'Orbitron', monospace;
        font-size: 0.9rem;
        font-weight: 600;
        color: rgb(81, 146, 89);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin: 0;
    }

    .gallery-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 300px;
        background: linear-gradient(135deg, rgba(24, 24, 24, 0.95) 0%, rgba(18, 18, 18, 0.95) 100%);
        border: 2px dashed rgba(81, 146, 89, 0.3);
        border-radius: 8px;
        padding: 40px;
        text-align: center;
    }

    .gallery-placeholder svg {
        width: 60px;
        height: 60px;
        color: rgba(81, 146, 89, 0.5);
        margin-bottom: 15px;
    }

    .gallery-placeholder p {
        color: rgba(255, 255, 255, 0.6);
        font-family: 'Rajdhani', sans-serif;
        font-size: 1.1rem;
    }

    .gallery-placeholder code {
        color: rgb(81, 146, 89);
        background: rgba(81, 146, 89, 0.1);
        padding: 2px 8px;
        border-radius: 4px;
        font-family: monospace;
    }

    /* Reveal Section */
    .reveal-section {
        position: relative;
    }

    .reveal-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 60px 20px;
        background: linear-gradient(135deg, rgba(24, 24, 24, 0.95) 0%, rgba(18, 18, 18, 0.95) 100%);
        border: 2px solid rgba(81, 146, 89, 0.4);
        border-radius: 8px;
        position: relative;
        overflow: hidden;
    }

    .reveal-container::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(81, 146, 89, 0.1), transparent);
        animation: reveal-shimmer 3s infinite;
    }

    @keyframes reveal-shimmer {
        0% { left: -100%; }
        100% { left: 100%; }
    }

    .reveal-icon {
