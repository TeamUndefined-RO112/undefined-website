                        </div>
                        <div class="gallery-item" onclick="openLightbox('/img/robots/vik/photo9.jpg', 'Photo 9')">
                            <img src="/img/robots/vik/photo9.jpg" alt="VIK Robot - Photo 9" />
                            <div class="gallery-overlay">
