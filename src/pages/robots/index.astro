                        </div>
                        <div class="gallery-item" onclick="openLightbox('/img/robots/vik/photo10.jpg', 'Photo 10')">
                            <img src="/img/robots/vik/photo10.jpg" alt="VIK Robot - Photo 10" />
                            <div class="gallery-overlay">
