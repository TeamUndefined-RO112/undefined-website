---
import Layout from "../../../layouts/Layout.astro";
---
<Layout title="Team Undefined - Apply">
	<section class="page-hero">
		<div class="hero-grid" aria-hidden="true"></div>
		<p class="eyebrow">Join Us</p>
		<h1 class="premium-h1">Apply to Team Undefined.</h1>
		<p class="hero-copy">
			We take new members every year, from experienced students to beginner middle schoolers. Complete the form below — it takes 2 minutes!
		</p>
		<div class="hero-actions">
			<a href="https://forms.gle/PaddngZuDx6NyQ4K8" target="_blank" rel="noopener noreferrer" class="premium-button premium-button-primary">Direct Link to Form</a>
		</div>
	</section>

	<section class="premium-section">
		<div class="section-shell">
			<div class="form-container glass-card reveal">
				<iframe
					src="https://docs.google.com/forms/d/e/1FAIpQLSeOaniZyB3sQac6tJ7pb6t48ipFRU7VPJ5ThmOdJbbKE4qSPw/viewform?embedded=true"
					frameborder="0"
					marginheight="0"
					marginwidth="0"
					title="Team Undefined Application Form"
				>Loading…</iframe>
			</div>
		</div>
	</section>

<style>
	.hero-copy {
		max-width: 620px;
		margin: 1.2rem auto 0;
		color: #d4d4d4;
		font-size: clamp(1rem, 2vw, 1.2rem);
		line-height: 1.7;
		text-align: center;
	}

	.hero-actions {
		display: flex;
		justify-content: center;
		gap: 0.9rem;
		margin-top: 2rem;
	}

	.form-container {
		padding: 1.5rem;
		overflow: hidden;
	}

	.form-container:hover {
		transform: none;
	}

	.form-container iframe {
		width: 100%;
		height: 2000px;
		border: none;
		border-radius: 14px;
	}

	@media (max-width: 640px) {
		.form-container {
			padding: 0.75rem;
		}
	}
</style>
</Layout>
