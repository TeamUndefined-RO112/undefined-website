---
import Layout from "../../layouts/Layout.astro";
---
<Layout title="Team Undefined - Contact">
	<section class="page-hero">
		<div class="hero-grid" aria-hidden="true"></div>
		<p class="eyebrow">Get in Touch</p>
		<h1 class="premium-h1">Let's Talk.</h1>
		<p style="max-width: 600px; margin: 1.2rem auto 0; color: #d4d4d4; font-size: clamp(1rem, 2vw, 1.2rem); line-height: 1.7; text-align: center;">
			We have all the time in the world for our sponsors. Ready to make an impact?
		</p>
	</section>

	<section class="premium-section">
		<div class="section-shell">
			<div class="contact-methods">
				<div class="contact-card glass-card reveal">
					<div class="contact-icon">
						<svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
						</svg>
					</div>
					<div class="contact-info">
						<p class="eyebrow" style="margin-bottom: 0.5rem;">Email Us</p>
						<a class="contact-value" href="mailto:teamundefined2021@gmail.com" target="_blank" rel="noreferrer">
							teamundefined2021@gmail.com
						</a>
					</div>
				</div>

				<div class="contact-card glass-card reveal">
					<div class="contact-icon">
						<svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
						</svg>
					</div>
					<div class="contact-info">
						<p class="eyebrow" style="margin-bottom: 0.5rem;">Call Us</p>
						<div class="phone-numbers">
							<div class="phone-item">
								<span class="phone-label">Sponsorships:</span>
								<div style="display: flex; align-items: center; gap: 8px;">
									<a class="contact-value" href="tel:+40736512723">+40 736 512 723</a>
									<button class="copy-btn" data-copy-phone="+40736512723" aria-label="Copy phone number">
										<svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
										</svg>
									</button>
								</div>
							</div>
							<div class="phone-item">
								<span class="phone-label">Technical:</span>
								<div style="display: flex; align-items: center; gap: 8px;">
									<a class="contact-value" href="tel:+40731813166">+40 731 813 166</a>
									<button class="copy-btn" data-copy-phone="+40731813166" aria-label="Copy phone number">
										<svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
										</svg>
									</button>
								</div>
							</div>
						</div>
						<p class="contact-note">(Please call after 3 PM RO timezone — we have classes!)</p>
					</div>
				</div>

				<div class="contact-card glass-card reveal">
					<div class="contact-icon">
						<svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
						</svg>
					</div>
					<div class="contact-info">
						<div style="display: flex; align-items: center; gap: 10px; margin-bottom: 8px;">
							<p class="eyebrow" style="margin-bottom: 0;">Shipping Address</p>
							<button class="copy-btn" id="copyAddressBtn" aria-label="Copy address">
								<svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
								</svg>
							</button>
						</div>
						<div class="contact-value" style="font-size: 1.1rem;">
							<span style="display: block;">Andrei Stahie / Stefan Birlica</span>
							<span style="display: block; margin-top: 5px;">Team Undefined</span>
						</div>
						<p class="contact-note" style="margin-top: 8px;">
							Colegiul National Nicolae Grigorescu<br/>
							Calea Doftanei 4, Câmpina 105600<br/>
							Prahova, Romania<br/>
							Phone: +40 731 813 166
						</p>
						<a href="https://www.google.com/maps/place//data=!4m2!3m1!1s0x40b300790628053f:0x74a7b0aca45472b0?sa=X&ved=1t:8290&ictx=111" target="_blank" rel="noopener noreferrer" class="maps-link">
							<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width: 16px; height: 16px; margin-right: 6px;">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
							</svg>
							View on Google Maps
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="premium-section" style="padding-top: 0;">
		<div class="section-shell">
			<div class="section-heading reveal" style="text-align: center; max-width: 100%;">
				<p class="eyebrow">Social Media</p>
				<h2 class="premium-h2">Find us online.</h2>
			</div>
			<div class="social-grid reveal">
				<a href="https://www.instagram.com/team_undefined/" target="_blank" rel="noreferrer" class="social-card glass-card">
					<img src="/img/ig.webp" alt="Instagram" style="width: 48px; height: 48px; border-radius: 12px;" />
					<span>Instagram</span>
				</a>
				<a href="https://www.facebook.com/teamundefinedcnng/" target="_blank" rel="noreferrer" class="social-card glass-card">
					<img src="/img/fb.webp" alt="Facebook" style="width: 48px; height: 48px; border-radius: 12px;" />
					<span>Facebook</span>
				</a>
			</div>
		</div>
	</section>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		// Handle phone number copy buttons
		const phoneCopyBtns = document.querySelectorAll('[data-copy-phone]');
		phoneCopyBtns.forEach(btn => {
			btn.addEventListener('click', () => {
				const phoneNumber = btn.getAttribute('data-copy-phone');
				const icon = btn.querySelector('.icon');

				navigator.clipboard.writeText(phoneNumber).then(() => {
					icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>';
					btn.classList.add('copied');

					setTimeout(() => {
						icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>';
						btn.classList.remove('copied');
					}, 2000);
				}).catch(err => {
					console.error('Failed to copy phone number:', err);
				});
			});
		});

		// Handle address copy button
		const copyAddressBtn = document.getElementById('copyAddressBtn');
		if (copyAddressBtn) {
			copyAddressBtn.addEventListener('click', () => {
				const address = `Andrei Stahie / Stefan Birlica
Team Undefined
Colegiul National Nicolae Grigorescu
Calea Doftanei 4
Câmpina 105600
Prahova, Romania
Phone: +40 731 813 166`;

				const icon = copyAddressBtn.querySelector('.icon');

				navigator.clipboard.writeText(address).then(() => {
					icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>';
					copyAddressBtn.classList.add('copied');

					setTimeout(() => {
						icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>';
						copyAddressBtn.classList.remove('copied');
					}, 2000);
				}).catch(err => {
					console.error('Failed to copy address:', err);
				});
			});
		}
	});
</script>

<style>
	.contact-methods {
		display: flex;
		flex-direction: column;
		gap: 1.2rem;
		max-width: 720px;
		margin: 0 auto;
	}

	.contact-card {
		display: flex;
		align-items: flex-start;
		gap: 1.5rem;
		padding: 1.8rem;
	}

	.contact-icon {
		width: 44px;
		height: 44px;
		flex-shrink: 0;
		display: grid;
		place-items: center;
		border: 1px solid rgba(34, 197, 94, 0.34);
		border-radius: 14px;
		color: #22c55e;
	}

	.contact-icon svg {
		width: 22px;
		height: 22px;
	}

	.contact-info {
		flex: 1;
	}

	.contact-value {
		font-size: 1.15rem;
		font-weight: 600;
		color: #22c55e;
		text-decoration: none;
		display: block;
		transition: color 0.3s ease;
	}

	.contact-value:hover {
		color: rgba(34, 197, 94, 0.8);
	}

	.contact-note {
		font-size: 0.88rem;
		color: rgba(255, 255, 255, 0.55);
		margin-top: 5px;
		font-style: italic;
	}

	.maps-link {
		display: inline-flex;
		align-items: center;
		margin-top: 12px;
		font-size: 0.75rem;
		font-weight: 800;
		color: #22c55e;
		text-decoration: none;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		transition: all 0.3s ease;
		padding: 0.65rem 1rem;
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.04);
	}

	.maps-link:hover {
		border-color: rgba(34, 197, 94, 0.5);
		box-shadow: 0 0 22px rgba(34, 197, 94, 0.15);
		transform: translateY(-2px);
	}

	.copy-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 12px;
		cursor: pointer;
		transition: all 0.25s ease;
		padding: 0;
	}

	.copy-btn:hover {
		background: rgba(34, 197, 94, 0.12);
		border-color: rgba(34, 197, 94, 0.5);
		transform: translateY(-2px);
		box-shadow: 0 0 18px rgba(34, 197, 94, 0.15);
	}

	.copy-btn.copied {
		background: rgba(34, 197, 94, 0.15);
		border-color: #22c55e;
	}

	.copy-btn .icon {
		width: 16px;
		height: 16px;
		color: #22c55e;
		transition: all 0.2s ease;
	}

	.phone-numbers {
		display: flex;
		flex-direction: column;
		gap: 12px;
		margin-bottom: 8px;
	}

	.phone-item {
		display: flex;
		flex-direction: column;
		gap: 5px;
	}

	.phone-label {
		font-size: 0.78rem;
		font-weight: 700;
		color: #a3a3a3;
		text-transform: uppercase;
		letter-spacing: 0.12em;
	}

	.social-grid {
		display: flex;
		justify-content: center;
		gap: 1.2rem;
		flex-wrap: wrap;
	}

	.social-card {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 1.2rem 2rem;
		text-decoration: none;
		min-width: 200px;
	}

	.social-card span {
		color: white;
		font-weight: 700;
		font-size: 1.05rem;
	}

	@media only screen and (max-width: 640px) {
		.contact-card {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}

		.contact-value {
			font-size: 1rem;
		}
	}
</style>
</Layout>
